@model Supercontrol.Web.Dashboard.Models.DashboardViewModel
@using System.Linq
@{
    ViewBag.Title = "Dashboard";

    string FormatChange(double? pct)
    {
        if (!pct.HasValue) return null;
        var sign = pct.Value >= 0 ? "+" : "";
        return sign + pct.Value.ToString("0.0") + "%";
    }

    string ChangeClass(double? pct) => pct.HasValue && pct.Value < 0 ? "negative" : "positive";
}

@section styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<div class="dash-dashboard">
<section class="dash-stats">
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10" />
                <line x1="12" y1="20" x2="12" y2="4" />
                <line x1="6" y1="20" x2="6" y2="14" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Bookings today</div>
            <div class="dash-stat-value" id="statBookingsToday">@Model.BookingsToday.ToString("N0")</div>
        </div>
        @{ var changeText = FormatChange(Model.BookingsTodayChangePercent); }
        <span class="dash-stat-badge dark" id="statBookingsTodayChange">@(changeText ?? "—")</span>
    </div>
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">New enquiries today</div>
            <div class="dash-stat-value" id="statEnquiries">@Model.EnquiriesToday.ToString("N0")</div>
        </div>
        <span class="dash-stat-badge count" id="statEnquiriesBadge">@Model.EnquiriesToday.ToString("N0")</span>
    </div>
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Bookings this week</div>
            <div class="dash-stat-value" id="statBookingsWeek">@Model.BookingsThisWeek.ToString("N0")</div>
        </div>
        <span class="dash-stat-badge count" id="statLiveHour" title="Booked in the last hour">@Model.LiveLastHour.ToString("N0")</span>
    </div>
</section>

<section class="dash-dark-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Global Booking Origins</h2>
            <div class="dash-legend dash-map-legend">
                <span class="dash-legend-item">
                    <span class="dash-legend-dot high"></span> High volume
                </span>
                <span class="dash-legend-item">
                    <span class="dash-legend-dot low"></span> Low volume
                </span>
            </div>
        </div>
        <div class="dash-map-container">
            <div id="dashMap" class="dash-map"></div>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Top Locations</h2>
            <div class="dash-card-subtitle">Where bookers are from (7 days)</div>
        </div>
        <div class="dash-locations" id="topLocations">
            @if (!Model.TopCountries.Any())
            {
                <div class="dash-live-empty">No booking-origin data in the last 7 days.</div>
            }
            @foreach (var loc in Model.TopCountries)
            {
                <div class="dash-location-item">
                    <span class="dash-location-rank">@(Model.TopCountries.IndexOf(loc) + 1)</span>
                    <span class="dash-location-flag">@loc.Flag</span>
                    <span class="dash-location-name">@loc.Name</span>
                    <span class="dash-location-value">@loc.Value.ToString("N0")</span>
                    <span class="dash-location-change @ChangeClass(loc.ChangePercent)">@(FormatChange(loc.ChangePercent) ?? "n/a")</span>
                </div>
            }
        </div>
    </div>
</section>

<section class="dash-charts-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Daily bookings</h2>
                <div class="dash-card-subtitle">Real bookings placed per day, last 14 days</div>
            </div>
        </div>
        <div class="dash-chart-container">
            <canvas id="performanceChart"></canvas>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Channel Distribution</h2>
                <div class="dash-card-subtitle">Where bookings come from (7 days)</div>
            </div>
        </div>
        <div class="dash-donut-container">
            <div class="dash-donut-chart">
                <canvas id="partnerChart"></canvas>
                <div class="dash-donut-center">
                    <div class="dash-donut-value" id="donutTotal">@Model.Channels.Sum(c => c.BookingCount).ToString("N0")</div>
                </div>
            </div>
            <div class="dash-donut-legend" id="donutLegend"></div>
        </div>
    </div>
</section>

<section class="dash-dark-section dash-live-section" style="grid-template-columns: 1fr;">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title"><span class="dash-live-dot"></span>Live bookings</h2>
            <div class="dash-card-subtitle" id="liveUpdatedAt">Updating every 30s</div>
        </div>
        <div class="dash-live-table" id="liveBookingsTable">
            <div class="dash-live-row header">
                <span>Booked</span>
                <span>Property / Owner</span>
                <span>Guest from</span>
                <span>Stay dates</span>
                <span>Channel</span>
                <span>Guests</span>
            </div>
            @if (!Model.RecentBookings.Any())
            {
                <div class="dash-live-empty">No recent bookings found.</div>
            }
            @foreach (var b in Model.RecentBookings)
            {
                <div class="dash-live-row">
                    <span title="@b.BookingDate">@(b.BookingDate?.ToString("dd MMM HH:mm"))</span>
                    <span>@(b.CottageName ?? "—") &middot; @b.OwnerCompany</span>
                    <span>@(string.IsNullOrWhiteSpace(b.CustomerTown) ? (b.CustomerCountry ?? "—") : b.CustomerTown + ", " + b.CustomerCountry)</span>
                    <span>@(b.CheckIn.HasValue ? b.CheckIn.Value.ToString("dd MMM") : "—")@(b.CheckOut.HasValue ? " – " + b.CheckOut.Value.ToString("dd MMM") : "")</span>
                    <span class="dash-live-channel">@(string.IsNullOrWhiteSpace(b.SourceID) ? b.BookingType : b.SourceID)</span>
                    <span>@(((b.Adults ?? 0) + (b.Children ?? 0)) > 0 ? ((b.Adults ?? 0) + (b.Children ?? 0)).ToString() : "—")</span>
                </div>
            }
        </div>
    </div>
</section>
</div>

@section scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script src="@Url.Content("~/Scripts/dashboard-map.js")"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var REFRESH_MS = 30000;
            var donutColors = ['#3b82f6', '#ef4444', '#2dd4bf', '#c4e830', '#a855f7', '#f59e0b'];

            DashboardMap.init('dashMap', { center: [30, 10], zoom: 2 });

            function loadMap() {
                var existing = DashboardMap.getLayer('activity');
                if (existing) DashboardMap.removeLayer('activity');
                DashboardMap.addGeoJsonLayer('activity', '@Url.Action("BookingOrigins", "Home")?t=' + Date.now())
                    .then(function () {
                        var map = DashboardMap.getMap();
                        if (map) map.invalidateSize();
                    });
            }
            loadMap();

            window.addEventListener('resize', function () {
                var map = DashboardMap.getMap();
                if (map) map.invalidateSize();
            });

            var accent = '#c4e830';
            var gridColor = 'rgba(255,255,255,0.06)';
            var textColor = '#9ca3af';

            var perfCtx = document.getElementById('performanceChart').getContext('2d');
            var gradient = perfCtx.createLinearGradient(0, 0, 0, 240);
            gradient.addColorStop(0, 'rgba(196, 232, 48, 0.3)');
            gradient.addColorStop(1, 'rgba(196, 232, 48, 0)');

            var trendData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                Model.Trend.Select(t => new { label = t.Day.ToString("dd MMM"), value = t.BookingCount })));

            var performanceChart = new Chart(perfCtx, {
                type: 'line',
                data: {
                    labels: trendData.map(function (d) { return d.label; }),
                    datasets: [{
                        data: trendData.map(function (d) { return d.value; }),
                        borderColor: accent,
                        backgroundColor: gradient,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            grid: { color: gridColor },
                            ticks: { color: textColor, font: { size: 11 } }
                        },
                        y: {
                            grid: { color: gridColor },
                            ticks: { color: textColor, font: { size: 11 } },
                            beginAtZero: true
                        }
                    }
                }
            });

            var channelData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                Model.Channels.Select(c => new { label = c.Channel, value = c.BookingCount })));

            var partnerChart = new Chart(document.getElementById('partnerChart'), {
                type: 'doughnut',
                data: {
                    labels: channelData.map(function (d) { return d.label; }),
                    datasets: [{
                        data: channelData.map(function (d) { return d.value; }),
                        backgroundColor: channelData.map(function (_, i) { return donutColors[i % donutColors.length]; }),
                        borderWidth: 0,
                        cutout: '75%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { enabled: true } }
                }
            });

            function renderDonutLegend(channels) {
                var total = channels.reduce(function (s, c) { return s + c.value; }, 0);
                var html = channels.map(function (c, i) {
                    var pct = total > 0 ? Math.round((c.value / total) * 100) : 0;
                    return '<div class="dash-donut-legend-item">' +
                        '<span class="dash-donut-legend-dot" style="background:' + donutColors[i % donutColors.length] + ';"></span>' +
                        '<span class="dash-donut-legend-label">' + c.label + '</span>' +
                        '<span class="dash-donut-legend-value">' + pct + '%</span></div>';
                }).join('');
                document.getElementById('donutLegend').innerHTML = html;
                document.getElementById('donutTotal').textContent = total.toLocaleString();
            }
            renderDonutLegend(channelData);

            function fmtChange(pct) {
                if (pct === null || pct === undefined) return 'n/a';
                var sign = pct >= 0 ? '+' : '';
                return sign + pct.toFixed(1) + '%';
            }

            function renderTopLocations(countries) {
                var el = document.getElementById('topLocations');
                if (!countries.length) {
                    el.innerHTML = '<div class="dash-live-empty">No booking-origin data in the last 7 days.</div>';
                    return;
                }
                el.innerHTML = countries.map(function (c, i) {
                    var cls = (c.ChangePercent || 0) < 0 ? 'negative' : 'positive';
                    return '<div class="dash-location-item">' +
                        '<span class="dash-location-rank">' + (i + 1) + '</span>' +
                        '<span class="dash-location-flag">' + c.Flag + '</span>' +
                        '<span class="dash-location-name">' + c.Name + '</span>' +
                        '<span class="dash-location-value">' + c.Value.toLocaleString() + '</span>' +
                        '<span class="dash-location-change ' + cls + '">' + fmtChange(c.ChangePercent) + '</span></div>';
                }).join('');
            }

            function renderLiveFeed(rows) {
                var el = document.getElementById('liveBookingsTable');
                var header = '<div class="dash-live-row header"><span>Booked</span><span>Property / Owner</span>' +
                    '<span>Guest from</span><span>Stay dates</span><span>Channel</span><span>Guests</span></div>';
                if (!rows.length) {
                    el.innerHTML = header + '<div class="dash-live-empty">No recent bookings found.</div>';
                    return;
                }
                el.innerHTML = header + rows.map(function (b) {
                    var booked = b.BookingDate ? new Date(b.BookingDate).toLocaleString([], { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
                    var checkIn = b.CheckIn ? new Date(b.CheckIn).toLocaleDateString([], { day: '2-digit', month: 'short' }) : null;
                    var checkOut = b.CheckOut ? new Date(b.CheckOut).toLocaleDateString([], { day: '2-digit', month: 'short' }) : null;
                    var stay = checkIn ? (checkIn + (checkOut ? ' – ' + checkOut : '')) : '—';
                    var from = b.CustomerTown ? (b.CustomerTown + ', ' + (b.CustomerCountry || '')) : (b.CustomerCountry || '—');
                    var guests = ((b.Adults || 0) + (b.Children || 0)) || '—';
                    var channel = b.SourceID && b.SourceID.trim() ? b.SourceID : b.BookingType;
                    return '<div class="dash-live-row">' +
                        '<span>' + booked + '</span>' +
                        '<span>' + (b.CottageName || '—') + ' &middot; ' + (b.OwnerCompany || '') + '</span>' +
                        '<span>' + from + '</span>' +
                        '<span>' + stay + '</span>' +
                        '<span class="dash-live-channel">' + channel + '</span>' +
                        '<span>' + guests + '</span></div>';
                }).join('');
            }

            function refresh() {
                fetch('@Url.Action("LiveSummary", "Home")')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        document.getElementById('statBookingsToday').textContent = data.BookingsToday.toLocaleString();
                        document.getElementById('statBookingsTodayChange').textContent = fmtChange(data.BookingsTodayChangePercent);
                        document.getElementById('statEnquiries').textContent = data.EnquiriesToday.toLocaleString();
                        document.getElementById('statEnquiriesBadge').textContent = data.EnquiriesToday.toLocaleString();
                        document.getElementById('statBookingsWeek').textContent = data.BookingsThisWeek.toLocaleString();
                        document.getElementById('statLiveHour').textContent = data.LiveLastHour.toLocaleString();

                        renderTopLocations(data.TopCountries || []);
                        renderLiveFeed(data.RecentBookings || []);

                        var trend = (data.Trend || []).map(function (t) {
                            return { label: new Date(t.Day).toLocaleDateString([], { day: '2-digit', month: 'short' }), value: t.BookingCount };
                        });
                        performanceChart.data.labels = trend.map(function (d) { return d.label; });
                        performanceChart.data.datasets[0].data = trend.map(function (d) { return d.value; });
                        performanceChart.update('none');

                        var channels = (data.Channels || []).map(function (c) { return { label: c.Channel, value: c.BookingCount }; });
                        partnerChart.data.labels = channels.map(function (d) { return d.label; });
                        partnerChart.data.datasets[0].data = channels.map(function (d) { return d.value; });
                        partnerChart.data.datasets[0].backgroundColor = channels.map(function (_, i) { return donutColors[i % donutColors.length]; });
                        partnerChart.update('none');
                        renderDonutLegend(channels);

                        loadMap();

                        document.getElementById('liveUpdatedAt').textContent = 'Updated ' + new Date().toLocaleTimeString();
                    })
                    .catch(function (err) { console.error('Dashboard refresh failed', err); });
            }

            setInterval(refresh, REFRESH_MS);
        })();
    </script>
}
