@{
    ViewBag.Title = "Dashboard";
}

<section class="dash-stats">
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10" />
                <line x1="12" y1="20" x2="12" y2="4" />
                <line x1="6" y1="20" x2="6" y2="14" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">November Performance</div>
            <div class="dash-stat-value">£24,580</div>
        </div>
        <span class="dash-stat-badge dark">+12.4%</span>
    </div>
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Enquiries</div>
            <div class="dash-stat-value">New</div>
        </div>
        <span class="dash-stat-badge count">9</span>
    </div>
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Calendar</div>
            <div class="dash-stat-value">July 2026</div>
        </div>
        <span class="dash-stat-badge count">31</span>
    </div>
</section>

<section class="dash-dark-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Status &ndash; Active region</h2>
            <div class="dash-legend">
                <span class="dash-legend-item">
                    <span class="dash-legend-dot high"></span> High score
                </span>
                <span class="dash-legend-item">
                    <span class="dash-legend-dot low"></span> Low score
                </span>
            </div>
        </div>
        <div class="dash-map-container">
            <svg class="dash-map-svg" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
                <rect width="800" height="400" fill="#0b141a" />
                <!-- Simplified world map regions -->
                <ellipse cx="180" cy="160" rx="90" ry="70" fill="#152028" />
                <ellipse cx="400" cy="140" rx="60" ry="50" fill="#152028" />
                <ellipse cx="520" cy="120" rx="50" ry="45" fill="#152028" />
                <ellipse cx="620" cy="200" rx="70" ry="55" fill="#152028" />
                <ellipse cx="300" cy="280" rx="55" ry="40" fill="#152028" />
                <ellipse cx="480" cy="300" rx="45" ry="35" fill="#152028" />
                <ellipse cx="700" cy="310" rx="50" ry="40" fill="#152028" />
                <!-- Activity dots -->
                <circle class="dash-map-dot" cx="400" cy="130" r="6" />
                <circle class="dash-map-dot" cx="420" cy="125" r="4" />
                <circle class="dash-map-dot" cx="500" cy="115" r="5" />
                <circle class="dash-map-dot" cx="515" cy="120" r="7" />
                <circle class="dash-map-dot" cx="530" cy="110" r="4" />
                <circle class="dash-map-dot" cx="545" cy="125" r="5" />
                <circle class="dash-map-dot" cx="560" cy="115" r="3" />
                <circle class="dash-map-dot" cx="180" cy="155" r="4" />
                <circle class="dash-map-dot dim" cx="620" cy="195" r="3" />
                <circle class="dash-map-dot dim" cx="300" cy="275" r="3" />
                <circle class="dash-map-dot dim" cx="700" cy="305" r="4" />
            </svg>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Top Locations</h2>
        </div>
        <div class="dash-locations">
            <div class="dash-location-item">
                <span class="dash-location-rank">1</span>
                <span class="dash-location-flag">🇩🇪</span>
                <span class="dash-location-name">Germany</span>
                <span class="dash-location-value">7,456</span>
                <span class="dash-location-change positive">+12.5%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">2</span>
                <span class="dash-location-flag">🇬🇧</span>
                <span class="dash-location-name">United Kingdom</span>
                <span class="dash-location-value">5,632</span>
                <span class="dash-location-change positive">+8.3%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">3</span>
                <span class="dash-location-flag">🇵🇱</span>
                <span class="dash-location-name">Poland</span>
                <span class="dash-location-value">2,497</span>
                <span class="dash-location-change positive">+11.2%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">4</span>
                <span class="dash-location-flag">🇳🇱</span>
                <span class="dash-location-name">Netherlands</span>
                <span class="dash-location-value">1,456</span>
                <span class="dash-location-change positive">+7.1%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">5</span>
                <span class="dash-location-flag">🇫🇷</span>
                <span class="dash-location-name">France</span>
                <span class="dash-location-value">1,203</span>
                <span class="dash-location-change positive">+5.8%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">6</span>
                <span class="dash-location-flag">🇺🇸</span>
                <span class="dash-location-name">USA</span>
                <span class="dash-location-value">987</span>
                <span class="dash-location-change positive">+3.2%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">7</span>
                <span class="dash-location-flag">🇦🇹</span>
                <span class="dash-location-name">Austria</span>
                <span class="dash-location-value">654</span>
                <span class="dash-location-change negative">-1.4%</span>
            </div>
            <div class="dash-location-item">
                <span class="dash-location-rank">8</span>
                <span class="dash-location-flag">🇨🇭</span>
                <span class="dash-location-name">Switzerland</span>
                <span class="dash-location-value">521</span>
                <span class="dash-location-change positive">+2.1%</span>
            </div>
        </div>
    </div>
</section>

<section class="dash-charts-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Daily performance</h2>
                <div class="dash-card-subtitle">Measured by performance of devices</div>
            </div>
        </div>
        <div class="dash-chart-container">
            <canvas id="performanceChart"></canvas>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Partner Distribution</h2>
                <div class="dash-card-subtitle">Measured by partner contribution</div>
            </div>
        </div>
        <div class="dash-donut-container">
            <div class="dash-donut-chart">
                <canvas id="partnerChart"></canvas>
                <div class="dash-donut-center">
                    <div class="dash-donut-value">14,198</div>
                </div>
            </div>
            <div class="dash-donut-legend">
                <div class="dash-donut-legend-item">
                    <span class="dash-donut-legend-dot" style="background: #3b82f6;"></span>
                    <span class="dash-donut-legend-label">Direct</span>
                    <span class="dash-donut-legend-value">42%</span>
                </div>
                <div class="dash-donut-legend-item">
                    <span class="dash-donut-legend-dot" style="background: #ef4444;"></span>
                    <span class="dash-donut-legend-label">Agents</span>
                    <span class="dash-donut-legend-value">35%</span>
                </div>
                <div class="dash-donut-legend-item">
                    <span class="dash-donut-legend-dot" style="background: #2dd4bf;"></span>
                    <span class="dash-donut-legend-label">Affiliates</span>
                    <span class="dash-donut-legend-value">23%</span>
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var accent = '#c4e830';
            var gridColor = 'rgba(255,255,255,0.06)';
            var textColor = '#9ca3af';

            var perfCtx = document.getElementById('performanceChart').getContext('2d');
            var gradient = perfCtx.createLinearGradient(0, 0, 0, 240);
            gradient.addColorStop(0, 'rgba(196, 232, 48, 0.3)');
            gradient.addColorStop(1, 'rgba(196, 232, 48, 0)');

            new Chart(perfCtx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        data: [320, 410, 380, 520, 490, 610, 580, 450, 530, 620, 590, 710, 680, 750],
                        borderColor: accent,
                        backgroundColor: gradient,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            grid: { color: gridColor },
                            ticks: { color: textColor, font: { size: 11 } }
                        },
                        y: {
                            grid: { color: gridColor },
                            ticks: { color: textColor, font: { size: 11 } },
                            beginAtZero: true
                        }
                    }
                }
            });

            new Chart(document.getElementById('partnerChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Direct', 'Agents', 'Affiliates'],
                    datasets: [{
                        data: [42, 35, 23],
                        backgroundColor: ['#3b82f6', '#ef4444', '#2dd4bf'],
                        borderWidth: 0,
                        cutout: '75%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { display: false }, tooltip: { enabled: true } }
                }
            });
        })();
    </script>
}
