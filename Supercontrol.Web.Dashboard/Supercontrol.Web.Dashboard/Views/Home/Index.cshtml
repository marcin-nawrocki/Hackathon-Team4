@using Supercontrol.Web.Dashboard.Models
@{
    ViewBag.Title = "Dashboard";
    var topLocations = ViewBag.TopLocations as List<TopLocationDto> ?? new List<TopLocationDto>();
    var affiliates = ViewBag.Affiliates as List<AffiliateDto> ?? new List<AffiliateDto>();
    var bookingsPerHour = ViewBag.BookingsPerHour as List<BookingsPerHourDto> ?? new List<BookingsPerHourDto>();
    var fromDate = ViewBag.FromDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var fromDateDisplay = ViewBag.FromDateDisplay as string ?? DateTime.Today.ToString("d MMMM yyyy");
    var totalBookings = ViewBag.TotalBookings as int? ?? 0;
    var dailyIncome = ViewBag.DailyIncome as decimal? ?? 0m;

    var maxLocation = topLocations.Count > 0 ? Math.Max(topLocations[0].C, 1) : 1;
    var activeMarkets = topLocations.Count;
    var affiliateTotal = affiliates.Sum(a => a.C);
    var peakBookings = bookingsPerHour.Count > 0 ? bookingsPerHour.Max(b => b.C) : 0;
}

@section styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<script>
    (function () {
        try {
            if (localStorage.getItem('dashTheme') === 'dark') {
                document.body.setAttribute('data-theme', 'dark');
            }
        } catch (e) { }
    })();
</script>

<div class="dash-dashboard">
<header class="dash-header">
    <div class="dash-brand">
        <img src="@Url.Content("~/Content/images/supercontrol-logo.png")" alt="SuperControl by Inhabit" class="dash-brand-logo" />
    </div>
    <div class="dash-header-right">
        <form method="get" action="@Url.Action("Index", "Home")" class="dash-header-control">
            <label for="fromDate">From</label>
            <input type="date"
                   id="fromDate"
                   name="fromDate"
                   class="dash-date-input"
                   value="@fromDate"
                   onchange="this.form.submit()" />
        </form>
        <div class="dash-header-control">
            <label for="refreshInterval">Refresh</label>
            <select id="refreshInterval" class="dash-date-input dash-refresh-select">
                <option value="0">Off</option>
                @for (var s = 5; s <= 60; s += 5)
                {
                    <option value="@s">Every @s sec</option>
                }
            </select>
        </div>
        <div class="dash-live">
            <span class="dash-live-dot"></span>
            LIVE
            <span class="dash-live-clock" id="liveClock">--:--:--</span>
        </div>
        <button type="button" class="dash-theme-toggle" id="themeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
            <svg class="dash-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg class="dash-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5" />
                <line x1="12" y1="1" x2="12" y2="3" />
                <line x1="12" y1="21" x2="12" y2="23" />
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                <line x1="1" y1="12" x2="3" y2="12" />
                <line x1="21" y1="12" x2="23" y2="12" />
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
        </button>
        <div class="dash-avatar">SC</div>
    </div>
</header>

<section class="dash-stats">
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Total bookings</div>
            <div class="dash-stat-value" id="statTotalBookings">@totalBookings.ToString("N0")</div>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
                <polyline points="17 6 23 6 23 12" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Daily income</div>
            <div class="dash-stat-value" id="statDailyIncome">@dailyIncome.ToString("C0")</div>
        </div>
    </div>
</section>

<section class="dash-dark-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Booking Origins</h2>
                <div class="dash-card-subtitle">Live geographic distribution of inbound reservations</div>
            </div>
            <div class="dash-legend">
                <span class="dash-legend-pill">
                    <span class="dash-legend-dot"></span>
                    <span id="activeMarketsPill">@activeMarkets active markets</span>
                </span>
            </div>
        </div>
        <div class="dash-map-wrap">
            <div class="dash-map-container">
                <div id="dashMap" class="dash-map"></div>
            </div>
            <span class="dash-map-caption">
                <span class="dash-legend-dot"></span>
                Booking origin size volume
            </span>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Top Markets</h2>
                <div class="dash-card-subtitle">Ranked by live booking volume</div>
            </div>
        </div>
        <div class="dash-locations" id="topLocations">
            @for (var i = 0; i < topLocations.Count; i++)
            {
                var location = topLocations[i];
                var country = string.IsNullOrWhiteSpace(location.CustomerCountry) ? "Unknown" : location.CustomerCountry;
                var flagUrl = Supercontrol.Web.Dashboard.Helpers.CountryFlag.UrlFor(location.CustomerCountry);
                var barWidth = (int)Math.Round(location.C * 100.0 / maxLocation);
                <div class="dash-location-item">
                    <span class="dash-location-rank">#@(i + 1)</span>
                    @if (flagUrl != null)
                    {
                        <img src="@flagUrl" class="dash-flag" alt="" />
                    }
                    <span class="dash-location-name">@country</span>
                    <span class="dash-location-bar"><span class="dash-location-bar-fill" style="width:@(barWidth)%"></span></span>
                    <span class="dash-location-value">@location.C.ToString("N0")</span>
                </div>
            }
        </div>
    </div>
</section>

<section class="dash-charts-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Bookings per hour</h2>
                <div class="dash-card-subtitle">Hourly booking volume from @fromDateDisplay</div>
            </div>
            <div class="dash-card-metric">
                <div class="dash-card-metric-value" id="peakBookings">@peakBookings.ToString("N0")</div>
                <div class="dash-card-metric-label">peak hour</div>
            </div>
        </div>
        <div class="dash-chart-container">
            <canvas id="performanceChart"></canvas>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Bookings by Partner</h2>
                <div class="dash-card-subtitle" id="partnerSubtitle">Channel mix — @affiliateTotal.ToString("N0") total</div>
            </div>
        </div>
        <div class="dash-chart-container">
            <canvas id="affiliateChart"></canvas>
        </div>
    </div>
</section>

<footer class="dash-footer">
    <div class="dash-footer-left">
        <span class="dash-live-dot"></span>
        Supercontrol Analytics &middot; Live data stream
    </div>
    <div>&copy; @DateTime.Now.Year Supercontrol Ltd &middot; All rights reserved</div>
</footer>
</div>

@section scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script src="@Url.Content("~/Scripts/dashboard-map.js")"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var dataUrl = '@Url.Action("DashboardData", "Home")?fromDate=@fromDate';

            var PARTNER_COLORS = ['#1e3a8a', '#f87171', '#fbbf24', '#f59e0b', '#94a3b8', '#7cb342', '#38bdf8', '#c084fc'];

            function themePalette() {
                var dark = document.body.getAttribute('data-theme') === 'dark';
                return {
                    accent: dark ? '#8bc34a' : '#7cb342',
                    grid: dark ? 'rgba(255, 255, 255, 0.07)' : 'rgba(16, 24, 40, 0.06)',
                    text: dark ? '#7d8895' : '#98a2b3',
                    legend: dark ? '#9aa7b4' : '#5b6675',
                    centerLabel: dark ? '#7d8895' : '#98a2b3',
                    centerValue: dark ? '#e6edf3' : '#1f2a37',
                    cardBorder: dark ? '#161b22' : '#ffffff'
                };
            }
            var theme = themePalette();
            var accent = theme.accent;
            var gridColor = theme.grid;
            var textColor = theme.text;

            /* Live clock */
            var clockEl = document.getElementById('liveClock');
            function tickClock() {
                if (!clockEl) return;
                var now = new Date();
                clockEl.textContent =
                    ('0' + now.getHours()).slice(-2) + ':' +
                    ('0' + now.getMinutes()).slice(-2) + ':' +
                    ('0' + now.getSeconds()).slice(-2);
            }
            tickClock();
            window.setInterval(tickClock, 1000);

            /* Map centered on the United Kingdom */
            DashboardMap.init('dashMap', { center: [54.0, -2.0], zoom: 5 });

            var topLocationsGeoJson = @Html.Raw(ViewBag.MapGeoJson ?? "{\"type\":\"FeatureCollection\",\"features\":[]}");
            var topLocationsLayer = DashboardMap.addGeoJsonData('topLocations', topLocationsGeoJson);
            var map = DashboardMap.getMap();

            DashboardMap.invalidateSize();
            window.setTimeout(function () { DashboardMap.invalidateSize(); }, 200);

            window.addEventListener('resize', function () {
                var m = DashboardMap.getMap();
                if (m) m.invalidateSize();
            });

            /* Area chart */
            var perfCtx = document.getElementById('performanceChart').getContext('2d');
            var perfGradient = perfCtx.createLinearGradient(0, 0, 0, 260);
            perfGradient.addColorStop(0, 'rgba(124, 179, 66, 0.35)');
            perfGradient.addColorStop(1, 'rgba(124, 179, 66, 0.02)');

            var perfChart = new Chart(perfCtx, {
                type: 'line',
                data: {
                    labels: [@Html.Raw(string.Join(", ", bookingsPerHour.Select(b => "'" + b.H.ToString("00") + ":00'")))],
                    datasets: [{
                        label: 'Bookings',
                        data: [@string.Join(", ", bookingsPerHour.Select(b => b.C))],
                        borderColor: accent,
                        backgroundColor: perfGradient,
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: accent,
                        pointBorderWidth: 2,
                        pointHoverRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                title: function (items) { return items.length ? items[0].label : ''; },
                                label: function (ctx) { return ctx.parsed.y.toLocaleString() + ' bookings'; }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: textColor, font: { size: 10 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 12 }
                        },
                        y: {
                            grid: { color: gridColor },
                            border: { display: false },
                            ticks: { color: textColor, font: { size: 11 } },
                            beginAtZero: true
                        }
                    }
                }
            });

            /* Doughnut chart with center total */
            var centerTextPlugin = {
                id: 'centerText',
                afterDraw: function (chart) {
                    var area = chart.chartArea;
                    if (!area) return;
                    var ctx = chart.ctx;
                    var cx = (area.left + area.right) / 2;
                    var cy = (area.top + area.bottom) / 2;
                    var total = chart.data.datasets[0].data.reduce(function (a, b) { return a + b; }, 0);
                    ctx.save();
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';
                    ctx.fillStyle = theme.centerLabel;
                    ctx.font = "600 11px Inter, sans-serif";
                    ctx.fillText('Total bookings', cx, cy - 13);
                    ctx.fillStyle = theme.centerValue;
                    ctx.font = "800 22px Inter, sans-serif";
                    ctx.fillText(total.toLocaleString(), cx, cy + 8);
                    ctx.restore();
                }
            };

            var affiliateChart = new Chart(document.getElementById('affiliateChart'), {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(string.Join(", ", affiliates.Select(a => "'" + (string.IsNullOrWhiteSpace(a.AffiliateId) ? "None" : a.AffiliateId).Replace("'", "\\'") + "'")))],
                    datasets: [{
                        data: [@string.Join(", ", affiliates.Select(a => a.C))],
                        backgroundColor: PARTNER_COLORS,
                        borderColor: theme.cardBorder,
                        borderWidth: 2,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '68%',
                    layout: { padding: 6 },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: theme.legend,
                                font: { size: 11 },
                                boxWidth: 8,
                                boxHeight: 8,
                                usePointStyle: true,
                                padding: 12
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    var total = ctx.dataset.data.reduce(function (a, b) { return a + b; }, 0);
                                    var pct = total ? Math.round(ctx.parsed / total * 1000) / 10 : 0;
                                    return ctx.label + ': ' + ctx.parsed.toLocaleString() + ' (' + pct + '%)';
                                }
                            }
                        }
                    }
                },
                plugins: [centerTextPlugin]
            });

            /* Helpers */
            function escapeHtml(value) {
                return String(value).replace(/[&<>"']/g, function (ch) {
                    switch (ch) {
                        case '&': return '&amp;';
                        case '<': return '&lt;';
                        case '>': return '&gt;';
                        case '"': return '&quot;';
                        default: return '&#39;';
                    }
                });
            }

            function renderTopLocations(list) {
                var container = document.getElementById('topLocations');
                if (!container) return;
                var max = list.length ? Math.max(list[0].value, 1) : 1;
                var html = '';
                for (var i = 0; i < list.length; i++) {
                    var loc = list[i];
                    var flagHtml = loc.flag
                        ? '<img src="' + encodeURI(loc.flag) + '" class="dash-flag" alt="">'
                        : '';
                    var width = Math.round(loc.value * 100 / max);
                    html += '<div class="dash-location-item">' +
                        '<span class="dash-location-rank">#' + loc.rank + '</span>' +
                        flagHtml +
                        '<span class="dash-location-name">' + escapeHtml(loc.country) + '</span>' +
                        '<span class="dash-location-bar"><span class="dash-location-bar-fill" style="width:' + width + '%"></span></span>' +
                        '<span class="dash-location-value">' + escapeHtml(loc.count) + '</span>' +
                        '</div>';
                }
                container.innerHTML = html;
            }

            function setText(id, value) {
                var el = document.getElementById(id);
                if (el) el.textContent = value;
            }

            function refreshData() {
                fetch(dataUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (response) {
                        if (!response.ok) throw new Error('Request failed');
                        return response.json();
                    })
                    .then(function (d) {
                        setText('statDailyIncome', d.dailyIncome);
                        setText('statTotalBookings', d.totalBookings);

                        var markets = d.topLocations || [];
                        setText('activeMarketsPill', markets.length + ' active markets');
                        renderTopLocations(markets);

                        if (topLocationsLayer) {
                            topLocationsLayer.clearLayers();
                            topLocationsLayer.addData(d.mapGeoJson);
                        }

                        perfChart.data.labels = d.bookingsPerHour.labels;
                        perfChart.data.datasets[0].data = d.bookingsPerHour.data;
                        perfChart.update();
                        var peak = d.bookingsPerHour.data.length ? Math.max.apply(null, d.bookingsPerHour.data) : 0;
                        setText('peakBookings', peak.toLocaleString());

                        affiliateChart.data.labels = d.affiliates.labels;
                        affiliateChart.data.datasets[0].data = d.affiliates.data;
                        affiliateChart.update();
                        var partnerTotal = d.affiliates.data.reduce(function (a, b) { return a + b; }, 0);
                        setText('partnerSubtitle', 'Channel mix \u2014 ' + partnerTotal.toLocaleString() + ' total');
                    })
                    .catch(function () { /* ignore transient refresh errors */ });
            }

            /* Dark mode toggle */
            function applyChartTheme() {
                perfChart.options.scales.x.ticks.color = theme.text;
                perfChart.options.scales.y.ticks.color = theme.text;
                perfChart.options.scales.y.grid.color = theme.grid;
                perfChart.data.datasets[0].borderColor = theme.accent;
                perfChart.data.datasets[0].pointBorderColor = theme.accent;
                perfChart.update();

                affiliateChart.data.datasets[0].borderColor = theme.cardBorder;
                affiliateChart.options.plugins.legend.labels.color = theme.legend;
                affiliateChart.update();
            }

            var themeToggle = document.getElementById('themeToggle');
            if (themeToggle) {
                themeToggle.addEventListener('click', function () {
                    var isDark = document.body.getAttribute('data-theme') === 'dark';
                    if (isDark) {
                        document.body.removeAttribute('data-theme');
                        window.localStorage.setItem('dashTheme', 'light');
                    } else {
                        document.body.setAttribute('data-theme', 'dark');
                        window.localStorage.setItem('dashTheme', 'dark');
                    }
                    theme = themePalette();
                    applyChartTheme();
                });
            }

            /* Auto refresh */
            var STORAGE_KEY = 'dashRefreshInterval';
            var select = document.getElementById('refreshInterval');
            if (select) {
                var saved = window.localStorage.getItem(STORAGE_KEY);
                if (saved !== null) {
                    select.value = saved;
                }

                var timer = null;
                function applyInterval() {
                    if (timer) {
                        window.clearInterval(timer);
                        timer = null;
                    }
                    var seconds = parseInt(select.value, 10);
                    if (seconds > 0) {
                        timer = window.setInterval(refreshData, seconds * 1000);
                    }
                }

                select.addEventListener('change', function () {
                    window.localStorage.setItem(STORAGE_KEY, select.value);
                    applyInterval();
                });

                applyInterval();
            }
        })();
    </script>
}
