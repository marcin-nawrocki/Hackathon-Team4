@using Supercontrol.Web.Dashboard.Models
@{
    ViewBag.Title = "Dashboard";
    var topLocations = ViewBag.TopLocations as List<TopLocationDto> ?? new List<TopLocationDto>();
    var affiliates = ViewBag.Affiliates as List<AffiliateDto> ?? new List<AffiliateDto>();
    var bookingsPerHour = ViewBag.BookingsPerHour as List<BookingsPerHourDto> ?? new List<BookingsPerHourDto>();
    var fromDate = ViewBag.FromDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var fromDateDisplay = ViewBag.FromDateDisplay as string ?? DateTime.Today.ToString("d MMMM yyyy");
    var totalBookings = ViewBag.TotalBookings as int? ?? 0;
    var dailyIncome = ViewBag.DailyIncome as decimal? ?? 0m;
}

@section styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
}

<div class="dash-dashboard">
<section class="dash-stats">
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Daily income</div>
            <div class="dash-stat-value" id="statDailyIncome">@dailyIncome.ToString("C0")</div>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                <rect x="8" y="2" width="8" height="4" rx="1" ry="1" />
                <line x1="9" y1="12" x2="15" y2="12" />
                <line x1="9" y1="16" x2="15" y2="16" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <div class="dash-stat-label">Total bookings</div>
            <div class="dash-stat-value" id="statTotalBookings">@totalBookings.ToString("N0")</div>
        </div>
    </div>
    <form method="get" action="@Url.Action("Index", "Home")" class="dash-stat-card dash-stat-card--date">
        <div class="dash-stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
        </div>
        <div class="dash-stat-content">
            <label class="dash-stat-label" for="fromDate">From date</label>
            <input type="date"
                   id="fromDate"
                   name="fromDate"
                   class="dash-date-input"
                   value="@fromDate"
                   onchange="this.form.submit()" />
        </div>
        <div class="dash-stat-content dash-stat-content--refresh">
            <label class="dash-stat-label" for="refreshInterval">Auto refresh</label>
            <select id="refreshInterval" class="dash-date-input dash-refresh-select">
                <option value="0">Off</option>
                @for (var s = 5; s <= 60; s += 5)
                {
                    <option value="@s">Every @s sec</option>
                }
            </select>
        </div>
    </form>
</section>

<section class="dash-dark-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Global Booking Origins</h2>
            <div class="dash-legend dash-map-legend">
                <span class="dash-legend-item">
                    <span class="dash-legend-dot high"></span> High volume
                </span>
                <span class="dash-legend-item">
                    <span class="dash-legend-dot low"></span> Low volume
                </span>
            </div>
        </div>
        <div class="dash-map-container">
            <div id="dashMap" class="dash-map"></div>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Top Locations</h2>
        </div>
        <div class="dash-locations" id="topLocations">
            @for (var i = 0; i < topLocations.Count; i++)
            {
                var location = topLocations[i];
                var country = string.IsNullOrWhiteSpace(location.CustomerCountry) ? "Unknown" : location.CustomerCountry;
                var flagUrl = Supercontrol.Web.Dashboard.Helpers.CountryFlag.UrlFor(location.CustomerCountry);
                <div class="dash-location-item">
                    <span class="dash-location-rank">@(i + 1)</span>
                    <span class="dash-location-name">
                        @if (flagUrl != null)
                        {
                            <img src="@flagUrl" class="dash-flag" alt="" />
                        }
                        @country
                    </span>
                    <span class="dash-location-value">@location.C.ToString("N0")</span>
                </div>
            }
        </div>
    </div>
</section>

<section class="dash-charts-section">
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Bookings per hour</h2>
                <div class="dash-card-subtitle">Booking volume by hour from @fromDateDisplay</div>
            </div>
        </div>
        <div class="dash-chart-container">
            <canvas id="performanceChart"></canvas>
        </div>
    </div>
    <div class="dash-dark-card">
        <div class="dash-card-header">
            <div>
                <h2 class="dash-card-title">Affiliates</h2>
                <div class="dash-card-subtitle">Bookings by affiliate from @fromDateDisplay</div>
            </div>
        </div>
        <div class="dash-chart-container">
            <canvas id="affiliateChart"></canvas>
        </div>
    </div>
</section>
</div>

@section scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script src="@Url.Content("~/Scripts/dashboard-map.js")"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var dataUrl = '@Url.Action("DashboardData", "Home")?fromDate=@fromDate';

            DashboardMap.init('dashMap', { center: [20, 0], zoom: 2 });

            var topLocationsGeoJson = @Html.Raw(ViewBag.MapGeoJson ?? "{\"type\":\"FeatureCollection\",\"features\":[]}");
            var topLocationsLayer = DashboardMap.addGeoJsonData('topLocations', topLocationsGeoJson);
            var map = DashboardMap.getMap();
            if (map && topLocationsLayer && topLocationsLayer.getBounds().isValid()) {
                map.fitBounds(topLocationsLayer.getBounds(), { padding: [40, 40], maxZoom: 4 });
            }

            DashboardMap.invalidateSize();

            window.addEventListener('resize', function () {
                var map = DashboardMap.getMap();
                if (map) map.invalidateSize();
            });

            var gridColor = 'rgba(255,255,255,0.06)';
            var textColor = '#9ca3af';

            var perfCtx = document.getElementById('performanceChart').getContext('2d');

            var perfChart = new Chart(perfCtx, {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(", ", bookingsPerHour.Select(b => "'" + b.H.ToString("00") + ":00'")))],
                    datasets: [{
                        label: 'Bookings',
                        data: [@string.Join(", ", bookingsPerHour.Select(b => b.C))],
                        backgroundColor: 'rgba(34, 211, 238, 0.75)',
                        hoverBackgroundColor: '#5eead4',
                        borderColor: '#22d3ee',
                        borderWidth: 1,
                        borderRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                title: function (items) {
                                    return items.length ? items[0].label : '';
                                },
                                label: function (ctx) {
                                    return ctx.parsed.y.toLocaleString() + ' bookings';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: textColor, font: { size: 10 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 12 }
                        },
                        y: {
                            grid: { color: gridColor },
                            ticks: { color: textColor, font: { size: 11 } },
                            beginAtZero: true
                        }
                    }
                }
            });

            var affiliateChart = new Chart(document.getElementById('affiliateChart'), {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(", ", affiliates.Select(a => "'" + (string.IsNullOrWhiteSpace(a.AffiliateId) ? "None" : a.AffiliateId).Replace("'", "\\'") + "'")))],
                    datasets: [{
                        data: [@string.Join(", ", affiliates.Select(a => a.C))],
                        backgroundColor: 'rgba(34, 211, 238, 0.75)',
                        hoverBackgroundColor: '#5eead4',
                        borderColor: '#22d3ee',
                        borderWidth: 1,
                        borderRadius: 4,
                        borderSkipped: false
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) { return ctx.parsed.x.toLocaleString() + ' bookings'; }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: gridColor },
                            ticks: { color: textColor, font: { size: 11 } },
                            beginAtZero: true
                        },
                        y: {
                            grid: { display: false },
                            ticks: { color: textColor, font: { size: 11 } }
                        }
                    }
                }
            });

            function escapeHtml(value) {
                return String(value).replace(/[&<>"']/g, function (ch) {
                    switch (ch) {
                        case '&': return '&amp;';
                        case '<': return '&lt;';
                        case '>': return '&gt;';
                        case '"': return '&quot;';
                        default: return '&#39;';
                    }
                });
            }

            function renderTopLocations(list) {
                var container = document.getElementById('topLocations');
                if (!container) return;
                var html = '';
                for (var i = 0; i < list.length; i++) {
                    var loc = list[i];
                    var flagHtml = loc.flag
                        ? '<img src="' + encodeURI(loc.flag) + '" class="dash-flag" alt="">'
                        : '';
                    html += '<div class="dash-location-item">' +
                        '<span class="dash-location-rank">' + loc.rank + '</span>' +
                        '<span class="dash-location-name">' + flagHtml + escapeHtml(loc.country) + '</span>' +
                        '<span class="dash-location-value">' + escapeHtml(loc.count) + '</span>' +
                        '</div>';
                }
                container.innerHTML = html;
            }

            function refreshData() {
                fetch(dataUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (response) {
                        if (!response.ok) throw new Error('Request failed');
                        return response.json();
                    })
                    .then(function (d) {
                        var income = document.getElementById('statDailyIncome');
                        var bookings = document.getElementById('statTotalBookings');
                        if (income) income.textContent = d.dailyIncome;
                        if (bookings) bookings.textContent = d.totalBookings;

                        renderTopLocations(d.topLocations);

                        if (topLocationsLayer) {
                            topLocationsLayer.clearLayers();
                            topLocationsLayer.addData(d.mapGeoJson);
                        }

                        perfChart.data.labels = d.bookingsPerHour.labels;
                        perfChart.data.datasets[0].data = d.bookingsPerHour.data;
                        perfChart.update();

                        affiliateChart.data.labels = d.affiliates.labels;
                        affiliateChart.data.datasets[0].data = d.affiliates.data;
                        affiliateChart.update();
                    })
                    .catch(function () { /* ignore transient refresh errors */ });
            }

            var STORAGE_KEY = 'dashRefreshInterval';
            var select = document.getElementById('refreshInterval');
            if (select) {
                var saved = window.localStorage.getItem(STORAGE_KEY);
                if (saved !== null) {
                    select.value = saved;
                }

                var timer = null;
                function applyInterval() {
                    if (timer) {
                        window.clearInterval(timer);
                        timer = null;
                    }
                    var seconds = parseInt(select.value, 10);
                    if (seconds > 0) {
                        timer = window.setInterval(refreshData, seconds * 1000);
                    }
                }

                select.addEventListener('change', function () {
                    window.localStorage.setItem(STORAGE_KEY, select.value);
                    applyInterval();
                });

                applyInterval();
            }
        })();
    </script>
}
